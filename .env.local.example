# Copy to .env.local and fill in. Use one or both providers.

# ---- Anthropic (Claude — required for the decision engine) ----
# https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Google (G Suite) ----
# GCP: https://console.cloud.google.com/ → Credentials → OAuth 2.0 Client ID (Web)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ---- Microsoft (Outlook + Calendar) ----
# Azure: https://portal.azure.com/ → App registrations → New registration. Add redirect URI:
#   Web → http://localhost:3000/api/auth/callback/microsoft
# API permissions: Mail.Read, Calendars.Read, User.Read (Application not required; Delegated only). Grant admin if needed.
MICROSOFT_CLIENT_ID=your-application-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/callback/microsoft
